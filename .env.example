# Progento self-hosted – copy to .env and adjust
# Required for pulling images from GitHub Container Registry
GHCR_OWNER=stefano-edgible

# Where to store data (default: ./volumes under this repo)
# On a server with a data disk use e.g. /data
PROGENTO_DATA_ROOT=.

# PostgreSQL (used by the API)
POSTGRES_PASSWORD=postgres

# Optional: use when Ollama or embedding run outside Docker (e.g. on host with GPU)
# Leave unset to run Ollama and embedding inside Docker (default)
# OLLAMA_URL=http://host.docker.internal:11434
# EMBEDDING_SERVICE_URL=http://host.docker.internal:8002

# Optional: smaller/faster model for Ollama (default phi)
# OLLAMA_MODEL=phi
