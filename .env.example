# Progento self-hosted – copy to .env and adjust
#
# Linux vs Mac: run `sudo ./setup-volumes.sh` once (see README).
#
# Required for pulling images from GitHub Container Registry
GHCR_OWNER=stefano-edgible

# Optional image tag (default latest). Use latest-arm64 only if you publish arm64-only images (no multi-arch latest).
# PROGENTO_IMAGE_TAG=latest-arm64

# Where to store data (default: ./volumes under this repo)
# On a server with a data disk use e.g. /data
PROGENTO_DATA_ROOT=.

# PostgreSQL (used by the API)
POSTGRES_PASSWORD=postgres

# Optional: use when Ollama or embedding run outside Docker (e.g. on host with GPU)
# Leave unset to run Ollama and embedding inside Docker (default)
# OLLAMA_URL=http://host.docker.internal:11434
# EMBEDDING_SERVICE_URL=http://host.docker.internal:8002
#
# External start scripts run scripts/ensure-external-host-services.sh first (default on).
# PROGENTO_AUTO_START_EXTERNAL=0
# Optional: if embedding is on the host and not running, run this before compose (bash -lc):
# PROGENTO_EMBEDDING_START_CMD="cd /path/to/Progento/embedding_service && python main.py"
# python main.py disables access logs by default; plain uvicorn main:app logs every request unless you add --no-access-log

# Embedding service (host or container): access logs are OFF by default (no per-request INFO lines).
# EMBEDDING_LOG_LEVEL=WARNING
# UVICORN_LOG_LEVEL=warning
# EMBEDDING_ACCESS_LOG=1

# Optional: smaller/faster model for Ollama (default phi)
# OLLAMA_MODEL=phi

# Optional: Progento API → Ollama HTTP timeouts (seconds). Default read 300. Increase for large models on CPU.
# Any reverse proxy in front of progento-api or progento-ui must allow at least OLLAMA_READ_TIMEOUT for long queries.
# OLLAMA_CONNECT_TIMEOUT=30
# OLLAMA_READ_TIMEOUT=600
